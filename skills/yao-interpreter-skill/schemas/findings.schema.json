{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yao.local/schemas/skill-interpreter-findings.schema.json",
  "title": "Yao Interpreter Findings",
  "$defs": {
    "evidence": {
      "type": "object",
      "required": ["file", "section", "quote", "fact_type", "confidence", "source_hash"],
      "properties": {
        "file": {"type": "string"},
        "section": {"type": "string"},
        "line_start": {"type": ["integer", "null"]},
        "line_end": {"type": ["integer", "null"]},
        "quote": {"type": "string"},
        "fact_type": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "source_hash": {"type": "string"}
      }
    },
    "finding": {
      "type": "object",
      "required": [
        "finding_id",
        "dimension_key",
        "dimension",
        "severity",
        "confidence",
        "summary",
        "score_delta",
        "evidence",
        "recommendation",
        "acceptance_criteria"
      ],
      "properties": {
        "finding_id": {"type": "string"},
        "dimension_key": {"type": "string"},
        "dimension": {"type": "string"},
        "severity": {"enum": ["low", "medium", "high", "critical"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "summary": {"type": "string"},
        "score_delta": {"type": "integer"},
        "evidence": {
          "type": "array",
          "items": {"$ref": "#/$defs/evidence"}
        },
        "recommendation": {"type": "string"},
        "acceptance_criteria": {"type": "string"}
      }
    }
  },
  "type": "array",
  "items": {
    "$ref": "#/$defs/finding"
  }
}
